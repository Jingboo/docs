{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Help Center",
  "description": "Documentation and guides for this template—workspace setup, product how-tos, and support.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "directory": "card",
    "products": [
      {
        "product": "Docs",
        "description": "Mintlify product documentation.",
        "icon": "book-open",
        "href": "https://www.mintlify.com/docs",
        "tabs": [
          {
            "tab": "Untitled Tab"
          }
        ]
      },
      {
        "product": "Guides",
        "description": "Best-practice guides for technical writing.",
        "icon": "compass",
        "href": "https://www.mintlify.com/guides/introduction"
      },
      {
        "product": "Articles",
        "description": "News, announcements, and engineering posts.",
        "icon": "newspaper",
        "href": "https://www.mintlify.com/blog"
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Get support",
        "href": "/support/contact-support"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  }
}
